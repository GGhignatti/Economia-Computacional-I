**Versão: 0.0.2**
"""

# Alocação de Memória
lado = 0.0
area = 0.0

# Entrada de Dados
lado = float(input("\nDigite o lado do quadrado que você quer calcular a área: "))

# Processamento de Dados
area = lado**2

# Saída de Dados
print(f"A área do quadrado de lado {lado} é igual {area}")
